# =====================================================================
# Slayer Legend Monitor — variáveis de ambiente
# =====================================================================
# Copie este arquivo para `.env` e preencha as 5 variáveis obrigatórias
# (marcadas com [OBRIGATÓRIO]). As demais já vêm com valores razoáveis.
# Veja README.md para o passo a passo de obtenção das credenciais.
# =====================================================================

# ---------------------------------------------------------------------
# VMOS Cloud OpenAPI — credenciais
# Obter em: vmoscloud.com → Personal Center → AccessKey
# ---------------------------------------------------------------------
# [OBRIGATÓRIO]
VMOS_ACCESS_KEY=seu_access_key_aqui
# [OBRIGATÓRIO]
VMOS_SECRET_KEY=seu_secret_key_aqui

VMOS_API_HOST=api.vmoscloud.com

# ID da instância (no painel: "ID do telefone na nuvem", ex.: APP64N6T7S3N8L6K).
# Múltiplas instâncias separadas por vírgula.
# [OBRIGATÓRIO]
VMOS_PAD_CODES=APP00000000000

# Pacote do Slayer Legend. Confirmado em diversas instâncias.
# Caso esteja diferente em sua conta, rode `python tools/diagnose.py`
# para descobrir o packageName real.
GAME_PACKAGE=com.gear2.growslayer

# ---------------------------------------------------------------------
# Telegram Bot
# Como criar: ver README.md (seção "Configurando o Telegram")
# ---------------------------------------------------------------------
# [OBRIGATÓRIO]
TELEGRAM_BOT_TOKEN=123456:ABC-seu-token
# [OBRIGATÓRIO]
TELEGRAM_CHAT_ID=123456789

# ---------------------------------------------------------------------
# Loop de verificação
# ---------------------------------------------------------------------
# 1200s = 20 min entre cada verificação
CHECK_INTERVAL_SECONDS=1200
REQUEST_TIMEOUT_SECONDS=20
# Cooldown anti-spam: o mesmo tipo de alerta não é repetido nesse intervalo
ALERT_COOLDOWN_SECONDS=1800

# ---------------------------------------------------------------------
# Fallback visual (screenshot via API VMOS + OpenCV) — recomendado
# ---------------------------------------------------------------------
# Detecta o caso "instância online, mas jogo crashou/saiu da tela".
# Antes de habilitar, capture seus templates do HUD — ver README.md
# (seção "Configurando o fallback visual").
ENABLE_VISUAL_FALLBACK=false

# Pasta com recortes de referência do HUD (PNG/JPG).
VISUAL_TEMPLATE_DIR=templates/hud

# Correlação mínima por template (0.0 a 1.0). 0.65 = permissivo, 0.85 = rigoroso.
VISUAL_MATCH_THRESHOLD=0.80

# Quantos templates precisam casar simultaneamente para confirmar o HUD.
# Mais alto = menos falso positivo. Recomendado 3 com 7+ templates.
VISUAL_MIN_MATCHES=3

# ---------------------------------------------------------------------
# Detecção de "frame congelado" — opcional, requer fallback visual ativo
# ---------------------------------------------------------------------
# Detecta o caso "jogo travou, mas a imagem do HUD continua na tela
# como se fosse um print". Custo: +1 chamada de API e +6s por ciclo.
ENABLE_FROZEN_CHECK=false

# Segundos entre as 2 capturas comparadas.
FROZEN_CHECK_DELAY_SECONDS=6

# Diferença média normalizada abaixo da qual o stream é considerado
# congelado. Calibre com `python tools/test_frozen.py` (ver README).
FROZEN_DIFF_THRESHOLD=0.02
